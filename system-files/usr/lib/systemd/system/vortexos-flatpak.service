[Unit]
Description=VortexOS — installa app Flatpak al primo avvio
After=network-online.target flatpak-system-helper.service
Wants=network-online.target
ConditionPathExists=!/var/lib/vortexos-flatpak.done

[Service]
Type=oneshot
ExecStart=/usr/libexec/vortexos-flatpak-install.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
